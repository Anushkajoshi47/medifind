{
  "expo": {
    "name": "MediFind",
    "slug": "medifind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#4F7DF3"
    },
    "ios": { "supportsTablet": true },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#4F7DF3" },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "Allow MediFind to use your location." }]
    ]
  }
}
